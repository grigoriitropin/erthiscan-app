<?xml version="1.0" encoding="utf-8"?>
<!-- 
    ADAPTIVE ROUND ICON: A variant of the launcher icon for devices that 
    specifically prefer circular shapes.

    Note: Android's adaptive icon system typically handles the mask (circle, 
    squircle, etc.) automatically, but having a dedicated 'round' resource 
    ensures compatibility with legacy or specific OEM implementations.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
    <monochrome android:drawable="@mipmap/ic_launcher_foreground"/>
</adaptive-icon>